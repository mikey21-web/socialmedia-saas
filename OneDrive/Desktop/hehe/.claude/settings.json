{
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm install)",
      "Bash(pnpm test)",
      "Bash(pnpm install)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)"
    ]
  },
  "model": "claude-sonnet-4-6",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/lint-on-save.sh"
          }
        ]
      }
    ]
  },
  "autoMemoryEnabled": true
}
