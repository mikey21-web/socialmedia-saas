datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  refreshTokenHash String?
  role      String   @default("user")
  suspended Boolean  @default(false)
  suspendedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  teams     TeamMember[]
  auditLogs AuditLog[]

  @@index([email])
  @@index([role])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  signature String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  members           TeamMember[]
  posts             Post[]
  credentials       PlatformCredential[]
  subscription      Subscription?
  postSets          PostSet[]
  thirdParties      ThirdPartyIntegration[]
  mediaAssets       MediaAsset[]
  rssSources        RssSource[]
  trendItems        TrendItem[]
  brandProfile      BrandProfile?
  agentRuns         AgentRun[]

  @@index([ownerId])
}

model TeamMember {
  id     String @id @default(cuid())
  userId String
  teamId String
  role   String @default("editor")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
}

model Post {
  id                String    @id @default(cuid())
  teamId            String
  title             String
  content           String
  mediaUrls         Json      @default("[]")
  status            String    @default("draft") // draft | awaiting_approval | approved | scheduled | published | rejected
  scheduledAt       DateTime?
  postDelay         Int?
  isRecurring       Boolean   @default(false)
  recurrencePattern String?
  recurrenceEndAt   DateTime?
  nextPublishAt     DateTime?
  postSetId         String?
  generatedBy       String?   // "user" | "content_agent" | "trend_agent"
  generationContext Json?     // { topic, intent, angle, runId }
  agentRunId        String?
  rejectionReason   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  team      Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  platforms PostPlatform[]
  analytics AnalyticsEvent[]
  postSet   PostSet?         @relation(fields: [postSetId], references: [id])
  comments  Comment[]

  @@index([teamId])
  @@index([status])
  @@index([postSetId])
}

model PostPlatform {
  id             String @id @default(cuid())
  postId         String
  platform       String
  platformPostId String?
  status         String @default("pending")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, platform])
}

model PlatformCredential {
  id           String   @id @default(cuid())
  teamId       String
  platform     String
  accountId    String?
  accountName  String?
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, platform, accountId])
  @@index([teamId])
  @@index([teamId, platform])
}

model Subscription {
  id               String   @id @default(cuid())
  teamId           String   @unique
  plan             String   @default("free")
  seats            Int      @default(1)
  stripeCustomerId String?
  stripePriceId    String?
  stripeId         String?
  status           String   @default("active")
  currentPeriodEnd DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  canceledAt       DateTime?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripePriceId])
  @@index([stripeId])
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  postId      String
  eventType   String
  count       Int      @default(1)
  collectedAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([eventType])
}

model PostSet {
  id          String    @id @default(cuid())
  teamId      String
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  team  Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  posts Post[]

  @@index([teamId])
}

model Comment {
  id         String    @id @default(cuid())
  postId     String
  teamId     String
  authorId   String
  content    String    @db.Text
  platform   String?
  externalId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([teamId])
}

model ThirdPartyIntegration {
  id         String   @id @default(cuid())
  teamId     String
  identifier String
  apiKey     String   @db.Text
  name       String?
  username   String?
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, identifier])
  @@index([teamId])
}

model MediaAsset {
  id        String   @id @default(cuid())
  teamId    String
  url       String
  filename  String
  mimeType  String
  size      Int      @default(0)
  width     Int?
  height    Int?
  source    String   @default("upload")
  tags      String[] @default([])
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([teamId, source])
}

model RssSource {
  id          String   @id @default(cuid())
  teamId      String
  url         String
  name        String?
  platforms   String[] @default([])
  autoPublish Boolean  @default(false)
  isActive    Boolean  @default(true)
  lastFetchAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model TrendItem {
  id             String   @id @default(cuid())
  teamId         String
  title          String
  summary        String   @db.Text
  url            String?
  source         String
  category       String?
  relevanceScore Float    @default(0)
  brandFitReason String?  @db.Text
  pillar         String?
  status         String   @default("pending")
  convertedPostId String?
  detectedAt     DateTime @default(now())
  expiresAt      DateTime

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([status])
  @@index([relevanceScore])
  @@index([detectedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetId   String
  targetType String
  metadata   Json?
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetId])
  @@index([action])
}

// ─── Brand Brain ──────────────────────────────────────────────────────────────

model BrandProfile {
  id              String   @id @default(cuid())
  teamId          String   @unique
  brandName       String
  industry        String
  description     String   @db.Text

  // Voice
  voiceTone       String
  voiceTraits     String[] @default([])
  formalityLevel  Int      @default(5)

  // Audience
  audienceAge     String
  audienceGender  String
  audienceLocation String[] @default([])
  audienceInterests String[] @default([])
  audiencePainPoints String[] @default([])

  // Goals
  primaryGoal     String
  secondaryGoals  String[] @default([])

  // Posting strategy
  platforms       String[] @default([])
  postsPerWeek    Json     @default("{}")
  contentMix      Json     @default("{}")

  // Voice rules
  alwaysWords     String[] @default([])
  neverWords      String[] @default([])
  emojiUsage      String   @default("moderate")
  hashtagStyle    String   @default("moderate")

  // Autonomy
  autonomousMode  Boolean  @default(false)
  approvalRequired Boolean @default(true)

  // Meta
  onboardingComplete Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  team            Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  pillars         ContentPillar[]
  competitors     Competitor[]
  voiceExamples   VoiceExample[]

  @@index([teamId])
}

model ContentPillar {
  id              String   @id @default(cuid())
  brandProfileId  String
  name            String
  description     String   @db.Text
  weight          Int      @default(20)
  keywords        String[] @default([])
  createdAt       DateTime @default(now())

  brandProfile    BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)

  @@index([brandProfileId])
}

model Competitor {
  id              String   @id @default(cuid())
  brandProfileId  String
  name            String
  handles         Json     @default("{}")
  url             String?
  notes           String?  @db.Text
  isActive        Boolean  @default(true)
  lastScrapedAt   DateTime?
  createdAt       DateTime @default(now())

  brandProfile    BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)
  snapshots       CompetitorSnapshot[]

  @@index([brandProfileId])
}

model CompetitorSnapshot {
  id              String   @id @default(cuid())
  competitorId    String
  platform        String
  postsCount      Int
  followersCount  Int?
  topPosts        Json     @default("[]")
  capturedAt      DateTime @default(now())

  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([competitorId])
  @@index([capturedAt])
}

model VoiceExample {
  id              String   @id @default(cuid())
  brandProfileId  String
  content         String   @db.Text
  platform        String?
  performanceScore Int?
  source          String   @default("manual")
  createdAt       DateTime @default(now())

  brandProfile    BrandProfile @relation(fields: [brandProfileId], references: [id], onDelete: Cascade)

  @@index([brandProfileId])
}

// ─── Agent Infrastructure ─────────────────────────────────────────────────────

model AgentRun {
  id              String    @id @default(cuid())
  teamId          String
  agentType       String
  status          String    @default("running")
  input           Json
  output          Json?
  error           String?
  steps           Json      @default("[]")
  startedAt       DateTime  @default(now())
  completedAt     DateTime?

  team            Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([agentType])
  @@index([status])
}
