datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  refreshTokenHash String?
  role      String   @default("user")
  suspended Boolean  @default(false)
  suspendedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  teams     TeamMember[]
  auditLogs AuditLog[]

  @@index([email])
  @@index([role])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  signature String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  members           TeamMember[]
  posts             Post[]
  credentials       PlatformCredential[]
  subscription      Subscription?
  postSets          PostSet[]
  thirdParties      ThirdPartyIntegration[]
  mediaAssets       MediaAsset[]
  rssSources        RssSource[]

  @@index([ownerId])
}

model TeamMember {
  id     String @id @default(cuid())
  userId String
  teamId String
  role   String @default("editor")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
}

model Post {
  id                String    @id @default(cuid())
  teamId            String
  title             String
  content           String
  mediaUrls         Json      @default("[]")
  status            String    @default("draft")
  scheduledAt       DateTime?
  postDelay         Int?
  isRecurring       Boolean   @default(false)
  recurrencePattern String?
  recurrenceEndAt   DateTime?
  nextPublishAt     DateTime?
  postSetId         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  team      Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  platforms PostPlatform[]
  analytics AnalyticsEvent[]
  postSet   PostSet?         @relation(fields: [postSetId], references: [id])
  comments  Comment[]

  @@index([teamId])
  @@index([status])
  @@index([postSetId])
}

model PostPlatform {
  id             String @id @default(cuid())
  postId         String
  platform       String
  platformPostId String?
  status         String @default("pending")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, platform])
}

model PlatformCredential {
  id           String   @id @default(cuid())
  teamId       String
  platform     String
  accountId    String?
  accountName  String?
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, platform, accountId])
  @@index([teamId])
  @@index([teamId, platform])
}

model Subscription {
  id               String   @id @default(cuid())
  teamId           String   @unique
  plan             String   @default("free")
  seats            Int      @default(1)
  stripeCustomerId String?
  stripePriceId    String?
  stripeId         String?
  status           String   @default("active")
  currentPeriodEnd DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  canceledAt       DateTime?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripePriceId])
  @@index([stripeId])
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  postId      String
  eventType   String
  count       Int      @default(1)
  collectedAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([eventType])
}

model PostSet {
  id          String    @id @default(cuid())
  teamId      String
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  team  Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  posts Post[]

  @@index([teamId])
}

model Comment {
  id         String    @id @default(cuid())
  postId     String
  teamId     String
  authorId   String
  content    String    @db.Text
  platform   String?
  externalId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([teamId])
}

model ThirdPartyIntegration {
  id         String   @id @default(cuid())
  teamId     String
  identifier String
  apiKey     String   @db.Text
  name       String?
  username   String?
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, identifier])
  @@index([teamId])
}

model MediaAsset {
  id        String   @id @default(cuid())
  teamId    String
  url       String
  filename  String
  mimeType  String
  size      Int      @default(0)
  width     Int?
  height    Int?
  source    String   @default("upload")
  tags      String[] @default([])
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([teamId, source])
}

model RssSource {
  id          String   @id @default(cuid())
  teamId      String
  url         String
  name        String?
  platforms   String[] @default([])
  autoPublish Boolean  @default(false)
  isActive    Boolean  @default(true)
  lastFetchAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetId   String
  targetType String
  metadata   Json?
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetId])
  @@index([action])
}
